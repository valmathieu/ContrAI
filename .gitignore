# ─── Python ────────────────────────────────────────────────────────────────
__pycache__/
*.py[oc]
*.egg-info/

# Build outputs (uv build, hatch, setuptools, ...).
build/
dist/
wheels/

# ─── Virtual environments ─────────────────────────────────────────────────
.venv/

# ─── Tooling caches ───────────────────────────────────────────────────────
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ─── Jupyter ──────────────────────────────────────────────────────────────
# Auto-saved shadows of .ipynb files. Cause noisy diffs and merge conflicts.
.ipynb_checkpoints/

# ─── Editors / IDEs ───────────────────────────────────────────────────────
.idea/
.vscode/

# ─── OS-generated files ───────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ─── AI assistants ────────────────────────────────────────────────────────
# Track shared Claude Code project config (.claude/settings.json, slash
# commands, hooks) but NOT per-user local overrides (machine-specific paths,
# personal preferences).
.claude/settings.local.json
CLAUDE.md